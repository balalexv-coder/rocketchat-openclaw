chat.balalexv.tech {
    # OpenClaw gateway — must be before the Rocket.Chat catch-all
    handle_path /openclaw/* {
        reverse_proxy localhost:18790
    }

    # Rocket.Chat (catch-all, includes WebSocket)
    handle {
        reverse_proxy localhost:3100
    }

    tls {
        protocols tls1.2 tls1.3
    }

    encode gzip zstd
}

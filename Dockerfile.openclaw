FROM ghcr.io/openclaw/openclaw:latest

# Install the Rocket.Chat community channel plugin
RUN npm install -g --force openclaw-rocketchat@latest 2>&1 || \
    npm install -g --legacy-peer-deps openclaw-rocketchat@latest

# Default port for this instance (overridden via env if needed)
ENV OPENCLAW_GATEWAY_PORT=18790
